{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "product_tags": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% for tag in product.tags limit: 2 %}{% assign tag_lower = tag | downcase %}{% if tag_lower == 'new' or tag_lower == 'sale' or tag_lower == 'sales' %}<span class=\"pdp-tag pdp-tag--{{ tag_lower }}\" style=\"display:inline-block;font-size:11px;font-weight:600;padding:4px 12px;border-radius:4px;margin-right:6px;margin-bottom:8px;{% if tag_lower == 'new' %}background:#e8f5e9;color:#2e7d32;{% elsif tag_lower == 'sale' or tag_lower == 'sales' %}background:#fce4ec;color:#c62828;{% endif %}\">{{ tag }}</span>{% endif %}{% endfor %}"
          }
        },
        "title": {
          "type": "title"
        },
        "category": {
          "type": "text",
          "settings": {
            "text": "Category: <a href=\"/collections/all\" style=\"color:#0d6e3a;\">{{ product.type }}</a>",
            "text_style": "subtitle"
          }
        },
        "rating": {
          "type": "rating"
        },
        "price": {
          "type": "price"
        },
        "inventory": {
          "type": "inventory",
          "settings": {
            "text_style": "body",
            "inventory_threshold": 10,
            "show_inventory_quantity": true
          }
        },
        "description": {
          "type": "description"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "none"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "shipping_info": {
          "type": "icon-with-text",
          "settings": {
            "layout": "horizontal",
            "icon_1": "truck",
            "heading_1": "Free International Shipping over $100",
            "icon_2": "return",
            "heading_2": "Free Returns Within 30 days",
            "icon_3": "none",
            "heading_3": ""
          }
        },
        "product_labels": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% for tag in product.tags %}{% assign tag_lower = tag | downcase %}{% if tag_lower == 'eco certified' or tag_lower == 'eco-certified' or tag_lower == 'warranty available' or tag_lower == 'variant available' %}<span style=\"display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:500;color:#555;padding:5px 12px;border:1px solid #e0e0e0;border-radius:20px;margin-right:6px;margin-top:4px;\">{% if tag_lower contains 'eco' %}<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#2e7d32' stroke-width='2'><path d='M12 2L2 7l10 5 10-5-10-5z'/><path d='M2 17l10 5 10-5'/><path d='M2 12l10 5 10-5'/></svg>{% elsif tag_lower contains 'warranty' %}<svg xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='#1565c0' stroke-width='2'><path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/></svg>{% endif %}{{ tag }}</span>{% endif %}{% endfor %}"
          }
        }
      },
      "block_order": [
        "product_tags",
        "title",
        "category",
        "rating",
        "price",
        "inventory",
        "description",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "shipping_info",
        "product_labels"
      ],
      "settings": {
        "enable_sticky_info": true,
        "gallery_layout": "thumbnail_slider",
        "media_size": "medium",
        "media_position": "left",
        "media_fit": "contain",
        "constrain_to_viewport": true,
        "image_zoom": "hover",
        "mobile_thumbnails": "show",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 24,
        "padding_bottom": 12
      }
    },
    "pdp-payment-security": {
      "type": "pdp-payment-security",
      "settings": {
        "heading": "Payment & Security",
        "disclaimer": "Your payment information is processed securely. We do not store credit card details nor have access to your credit card information."
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You May Also Like",
        "heading_size": "h2",
        "products_to_show": 5,
        "columns_desktop": 5,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": true,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "pdp-trust-bar": {
      "type": "pdp-trust-bar",
      "blocks": {
        "trust_shipping": {
          "type": "trust_item",
          "settings": {
            "icon": "shipping",
            "heading": "Free Shipping",
            "description": "All orders are shipped free of charge. No hidden fees or additional charges.",
            "link_label": "Shipping Details"
          }
        },
        "trust_returns": {
          "type": "trust_item",
          "settings": {
            "icon": "returns",
            "heading": "30-Days Free Returns",
            "description": "Our satisfaction guarantee lets you return any item within 30 days for a full refund or store credit.",
            "link_label": "Return Policy"
          }
        },
        "trust_secure": {
          "type": "trust_item",
          "settings": {
            "icon": "secure",
            "heading": "Secure Payment",
            "description": "Shop with confidence knowing your payments are encrypted and secured on our platform.",
            "link_label": "More About Payment"
          }
        }
      },
      "block_order": ["trust_shipping", "trust_returns", "trust_secure"],
      "settings": {}
    },
    "pdp-support": {
      "type": "homepage-contact-support",
      "settings": {
        "heading": "Get in Touch",
        "subheading": "We're here to help with any questions or concerns",
        "service_timing": "Mon-Fri: 8AM - 6PM EST",
        "phone": "(800) 555-0199",
        "email": "support@example.com",
        "address": "123 Business Ave, Suite 100, City, ST 12345"
      }
    }
  },
  "order": [
    "main",
    "pdp-payment-security",
    "related-products",
    "pdp-trust-bar",
    "pdp-support"
  ]
}

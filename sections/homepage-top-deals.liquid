{{ 'homepage-top-deals.css' | asset_url | stylesheet_tag }}

{%- assign deals_collection = section.settings.collection -%}

<section class="homepage-top-deals" id="homepage-top-deals">
  <div class="homepage-top-deals__inner">
    <div class="homepage-top-deals__header">
      <h2 class="homepage-top-deals__title">{{ section.settings.heading | default: 'Top Deals' }}</h2>
      <div class="homepage-top-deals__nav">
        <button class="homepage-top-deals__nav-btn" id="deals-prev" aria-label="Previous" onclick="document.getElementById('deals-scroll').scrollBy({left:-320, behavior:'smooth'})">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button class="homepage-top-deals__nav-btn" id="deals-next" aria-label="Next" onclick="document.getElementById('deals-scroll').scrollBy({left:320, behavior:'smooth'})">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <div class="homepage-top-deals__carousel" id="deals-scroll">
      <!-- Promo Banner Card -->
      <div class="homepage-top-deals__promo-card">
        {%- if section.settings.promo_image != blank -%}
          <img class="homepage-top-deals__promo-bg" src="{{ section.settings.promo_image | image_url: width: 800 }}" alt="{{ section.settings.promo_heading | escape }}" loading="lazy">
        {%- endif -%}
        <div class="homepage-top-deals__promo-content">
          <h3 class="homepage-top-deals__promo-heading">{{ section.settings.promo_heading | default: "Get ready for a deal you can't miss" }}</h3>
          {%- if section.settings.promo_button_label != blank -%}
            <a href="{{ section.settings.promo_button_link | default: '/collections/all' }}" class="homepage-top-deals__promo-btn" id="deals-shop-now">
              {{ section.settings.promo_button_label }}
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Product Cards from Collection -->
      {%- if deals_collection != blank -%}
        {%- for product in deals_collection.products limit: section.settings.products_to_show -%}
          <a href="{{ product.url }}" class="homepage-top-deals__deal-card" id="deal-{{ forloop.index }}">
            <div class="homepage-top-deals__deal-image">
              {%- assign tag_count = 0 -%}
              {%- for tag in product.tags limit: 2 -%}
                {%- assign tag_lower = tag | downcase -%}
                {%- if tag_lower == 'new' or tag_lower == 'sale' or tag_lower == 'certified refurbished' or tag_lower == 'like new' or tag_lower == 'refurbished' -%}
                  <span class="homepage-top-deals__deal-tag {% if tag_lower == 'sale' %}homepage-top-deals__deal-tag--red{% elsif tag_lower == 'new' or tag_lower == 'like new' %}homepage-top-deals__deal-tag--blue{% else %}homepage-top-deals__deal-tag--green{% endif %}">{{ tag }}</span>
                  {%- assign tag_count = tag_count | plus: 1 -%}
                {%- endif -%}
                {%- if tag_count >= 2 -%}{%- break -%}{%- endif -%}
              {%- endfor -%}
              {%- if product.compare_at_price > product.price -%}
                {%- assign discount = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price -%}
                <span class="homepage-top-deals__deal-badge">-{{ discount }}%</span>
              {%- endif -%}
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 560 }}" alt="{{ product.title | escape }}" loading="lazy" width="280" height="210">
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
            <div class="homepage-top-deals__deal-body">
              {%- if product.type != blank -%}
                <span class="homepage-top-deals__deal-category">{{ product.type }}</span>
              {%- endif -%}
              <h3 class="homepage-top-deals__deal-title">{{ product.title }}</h3>
              <div class="homepage-top-deals__deal-prices">
                <span class="homepage-top-deals__deal-price">{{ product.price | money }}</span>
                {%- if product.compare_at_price > product.price -%}
                  <span class="homepage-top-deals__deal-price-old">{{ product.compare_at_price | money }}</span>
                {%- endif -%}
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          <div class="homepage-top-deals__deal-card">
            <div class="homepage-top-deals__deal-image">
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
            <div class="homepage-top-deals__deal-body">
              <h3 class="homepage-top-deals__deal-title">Select a collection in section settings</h3>
              <div class="homepage-top-deals__deal-prices">
                <span class="homepage-top-deals__deal-price">$0.00</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Top Deals Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Top Deals"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Products to show"
    },
    {
      "type": "header",
      "content": "Promo Banner"
    },
    {
      "type": "image_picker",
      "id": "promo_image",
      "label": "Promo Background Image"
    },
    {
      "type": "text",
      "id": "promo_heading",
      "label": "Promo Heading",
      "default": "Get ready for a deal you can't miss"
    },
    {
      "type": "text",
      "id": "promo_button_label",
      "label": "Promo Button Label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "promo_button_link",
      "label": "Promo Button Link"
    }
  ],
  "presets": [
    {
      "name": "Top Deals Carousel"
    }
  ]
}
{% endschema %}

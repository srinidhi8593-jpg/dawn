{{ 'pdp-trust-bar.css' | asset_url | stylesheet_tag }}

<section class="pdp-trust-bar" id="pdp-trust-bar">
  <div class="pdp-trust-bar__inner">
    <div class="pdp-trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="pdp-trust-bar__item" {{ block.shopify_attributes }}>
          <div class="pdp-trust-bar__icon">
            {%- if block.settings.icon_image != blank -%}
              <img src="{{ block.settings.icon_image | image_url: width: 64 }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="32" height="32">
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'shipping' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
                  </svg>
                {%- when 'returns' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                  </svg>
                {%- when 'secure' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
                  </svg>
                {%- endcase -%}
            {%- endif -%}
          </div>
          {%- if block.settings.heading != blank -%}
            <h3 class="pdp-trust-bar__heading">{{ block.settings.heading }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="pdp-trust-bar__desc">{{ block.settings.description }}</p>
          {%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link_url | default: '#' }}" class="pdp-trust-bar__link">
              {{ block.settings.link_label }}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "PDP Trust Bar",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "options": [
            { "value": "shipping", "label": "Shipping truck" },
            { "value": "returns", "label": "Returns arrow" },
            { "value": "secure", "label": "Security shield" },
            { "value": "check", "label": "Checkmark" }
          ],
          "default": "shipping",
          "label": "Icon"
        },
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom Icon (overrides default)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free Shipping"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "All orders are shipped free of charge. No hidden fees or additional charges."
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link Label",
          "default": "Shipping Details"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PDP Trust Bar",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon": "shipping",
            "heading": "Free Shipping",
            "description": "All orders are shipped free of charge. No hidden fees or additional charges.",
            "link_label": "Shipping Details"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "returns",
            "heading": "30-Days Free Returns",
            "description": "Our satisfaction guarantee lets you return any item within 30 days for a full refund or store credit.",
            "link_label": "Return Policy"
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon": "secure",
            "heading": "Secure Payment",
            "description": "Shop with confidence knowing your payments are encrypted and secured on our platform.",
            "link_label": "More About Payment"
          }
        }
      ]
    }
  ]
}
{% endschema %}

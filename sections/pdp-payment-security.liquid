{{ 'pdp-payment-security.css' | asset_url | stylesheet_tag }}

<section class="pdp-payment-security" id="pdp-payment-security">
  <div class="pdp-payment-security__inner">
    <h2 class="pdp-payment-security__heading">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      {{ section.settings.heading | default: 'Payment & Security' }}
    </h2>

    <div class="pdp-payment-security__icons">
      {%- for type in shop.enabled_payment_types -%}
        <div class="pdp-payment-security__icon">
          {{ type | payment_type_svg_tag }}
        </div>
      {%- endfor -%}
    </div>

    {%- if section.settings.disclaimer != blank -%}
      <p class="pdp-payment-security__text">{{ section.settings.disclaimer }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Payment & Security",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Payment & Security"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Security Disclaimer",
      "default": "Your payment information is processed securely. We do not store credit card details nor have access to your credit card information."
    }
  ],
  "presets": [
    {
      "name": "Payment & Security"
    }
  ]
}
{% endschema %}

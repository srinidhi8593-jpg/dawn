{{ 'homepage-support.css' | asset_url | stylesheet_tag }}

<section class="homepage-support" id="homepage-value-prop">
  <div class="homepage-support__inner">
    <div class="homepage-support__layout">
      {%- if section.settings.image != blank -%}
        <div class="homepage-support__image-wrap">
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | escape }}" loading="lazy" width="400" height="400" class="homepage-support__image">
        </div>
      {%- endif -%}
      <div class="homepage-support__content">
        {%- if section.settings.subtitle != blank -%}
          <p class="homepage-support__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.icon != blank -%}
          <div class="homepage-support__icon">
            <img src="{{ section.settings.icon | image_url: width: 160 }}" alt="Badge" loading="lazy" width="80" height="80">
          </div>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="homepage-support__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <p class="homepage-support__desc">{{ section.settings.description }}</p>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="homepage-support__btn" id="value-prop-learn-more">
            {{ section.settings.button_label }}
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Value Proposition",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Section Image"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon / Badge"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "powered by industry-best certifications"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Comprehensive Support, Optimized Outcomes"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Our team of certified experts provides end-to-end support, from selecting the right device to ongoing technical assistance. We're committed to delivering optimized outcomes for every customer."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Value Proposition"
    }
  ]
}
{% endschema %}

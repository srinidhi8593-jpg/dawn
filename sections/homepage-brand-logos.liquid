{{ 'homepage-brand-logos.css' | asset_url | stylesheet_tag }}

<section class="homepage-brand-logos" id="homepage-brand-logos">
  <div class="homepage-brand-logos__inner">
    <div class="homepage-brand-logos__item">
      <span style="color:#0b3e91;font-weight:800;font-size:16px;">NASA</span>
    </div>
    <div class="homepage-brand-logos__item">
      <svg width="60" height="24" viewBox="0 0 60 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <text x="0" y="18" font-family="Arial, sans-serif" font-size="16" font-weight="700" fill="#0068B5">intel</text>
      </svg>
    </div>
    <div class="homepage-brand-logos__item">
      <span style="color:#76b900;font-weight:800;font-size:14px;">NVIDIA</span>
    </div>
    <div class="homepage-brand-logos__item">
      <svg width="80" height="26" viewBox="0 0 80 26" fill="none" xmlns="http://www.w3.org/2000/svg">
        <text x="0" y="19" font-family="Arial, sans-serif" font-size="16" font-weight="700" fill="#FF9900">amazon</text>
      </svg>
    </div>
    <div class="homepage-brand-logos__item">
      <span style="color:#0096D6;font-weight:800;font-size:18px;">hp</span>
    </div>
    <div class="homepage-brand-logos__item">
      <svg width="20" height="24" viewBox="0 0 20 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M15.5 1C14.2 3.2 11.4 4.8 10 5.2C8.6 4.8 5.8 3.2 4.5 1C2.8 3.6 2 6.4 2 9.6C2 14.8 5.6 19.2 10 23C14.4 19.2 18 14.8 18 9.6C18 6.4 17.2 3.6 15.5 1Z" fill="#555555"/>
      </svg>
    </div>
    <div class="homepage-brand-logos__item">
      <span style="color:#83B81A;font-weight:700;font-size:15px;">acer</span>
    </div>
    <div class="homepage-brand-logos__item">
      <span style="color:#007DB8;font-weight:800;font-size:16px;">DELL</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Brand Logos Strip",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [],
  "presets": [
    {
      "name": "Brand Logos Strip"
    }
  ]
}
{% endschema %}

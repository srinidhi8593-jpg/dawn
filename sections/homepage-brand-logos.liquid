{{ 'homepage-brand-logos.css' | asset_url | stylesheet_tag }}

<section class="homepage-brand-logos" id="homepage-brand-logos">
  <div class="homepage-brand-logos__inner">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: '/collections/all' }}" class="homepage-brand-logos__item" id="brand-{{ forloop.index }}" {{ block.shopify_attributes }}>
        {%- if block.settings.logo != blank -%}
          <img src="{{ block.settings.logo | image_url: width: 200 }}" alt="{{ block.settings.name | escape }}" loading="lazy" width="100" height="40">
        {%- else -%}
          <span>{{ block.settings.name }}</span>
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Brand Carousel",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "brand",
      "name": "Brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Brand Logo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Brand Name",
          "default": "Brand"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Brand Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Carousel",
      "blocks": [
        { "type": "brand", "settings": { "name": "Apple" } },
        { "type": "brand", "settings": { "name": "Dell" } },
        { "type": "brand", "settings": { "name": "Google" } },
        { "type": "brand", "settings": { "name": "Samsung" } },
        { "type": "brand", "settings": { "name": "HP" } },
        { "type": "brand", "settings": { "name": "Lenovo" } }
      ]
    }
  ]
}
{% endschema %}

{{ 'homepage-categories.css' | asset_url | stylesheet_tag }}

<section class="homepage-categories" id="homepage-categories">
  <div class="homepage-categories__inner">
    <div class="homepage-categories__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '/collections/all' }}" class="homepage-categories__item" id="category-{{ forloop.index }}" {{ block.shopify_attributes }}>
          <div class="homepage-categories__icon">
            {%- if block.settings.icon != blank -%}
              <img src="{{ block.settings.icon | image_url: width: 96 }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="48" height="48">
            {%- else -%}
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                {%- case block.settings.label -%}
                  {%- when 'Laptops' -%}
                    <rect x="2" y="3" width="20" height="14" rx="2"/><path d="M2 17h20M8 21h8"/>
                  {%- when 'Desktops' -%}
                    <rect x="4" y="2" width="16" height="12" rx="1"/><path d="M12 14v4M8 18h8"/>
                  {%- when 'Smartphones' -%}
                    <rect x="7" y="2" width="10" height="20" rx="2"/><path d="M11 18h2"/>
                  {%- when 'Tablets' -%}
                    <rect x="5" y="2" width="14" height="20" rx="2"/><path d="M11 18h2"/>
                  {%- when 'Gaming' -%}
                    <rect x="2" y="6" width="20" height="12" rx="2"/><path d="M6 12h4M8 10v4M15 11h.01M18 13h.01"/>
                  {%- when 'Servers/Networking' -%}
                    <rect x="2" y="2" width="20" height="6" rx="1"/><rect x="2" y="10" width="20" height="6" rx="1"/><path d="M6 5h.01M6 13h.01M18 18v4M12 18v4M6 18v4"/>
                  {%- when 'Accessories' -%}
                    <path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><path d="M4 22v-7"/>
                  {%- when 'Healthcare' -%}
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/>
                  {%- else -%}
                    <rect x="3" y="3" width="18" height="18" rx="2"/><path d="M12 8v8M8 12h8"/>
                  {%- endcase -%}
              </svg>
            {%- endif -%}
          </div>
          <span class="homepage-categories__label">{{ block.settings.label }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Category Icons",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 12,
  "settings": [],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Category Icon"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Category Label",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Icons",
      "blocks": [
        { "type": "category", "settings": { "label": "Laptops" } },
        { "type": "category", "settings": { "label": "Desktops" } },
        { "type": "category", "settings": { "label": "Smartphones" } },
        { "type": "category", "settings": { "label": "Tablets" } },
        { "type": "category", "settings": { "label": "Gaming" } },
        { "type": "category", "settings": { "label": "Servers/Networking" } },
        { "type": "category", "settings": { "label": "Accessories" } },
        { "type": "category", "settings": { "label": "Healthcare" } }
      ]
    }
  ]
}
{% endschema %}
